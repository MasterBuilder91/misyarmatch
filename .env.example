# ─── Database (Railway provides this automatically) ───────────────────────────
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=your-random-secret-here

# From Google Cloud Console → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Also set this as a Vite env var for the frontend
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_ID=misyarmatch

# Your Google user ID (you'll get this after first login, check DB)
# Leave blank for now, set after first deploy
OWNER_OPEN_ID=

# ─── Stripe (add later when ready to charge) ──────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ─── AWS S3 for profile photo uploads (optional initially) ────────────────────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=misyarmatch-uploads
